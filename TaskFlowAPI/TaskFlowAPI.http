@apiHttpBase = http://localhost:5072
@apiHttpsBase = https://localhost:7208

@apiBase = {{apiHttpBase}}
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..LsVYu8y120Kl2pLEvXlLLhqYflW0Og196pXfGXyQJ38

### Users - Register
POST {{apiBase}}/api/users
Content-Type: application/json

{
  "name": "Pierre",
  "email": "pierre2@example.com",
  "password": "hash-de-test",
  "role": 0
}

###

### Users - Login
POST {{apiBase}}/api/users/login
Content-Type: application/json

{
  "email": "pierre2@example.com",
  "password": "hash-de-test"
}

###

### Users - Get all
GET {{apiBase}}/api/users
Authorization: Bearer {{authToken}}
Accept: application/json

###

### Users - Get by id
GET {{apiBase}}/api/users/1
Authorization: Bearer {{authToken}}
Accept: application/json

###


### Projects - Get all
GET {{apiBase}}/api/projects
Accept: application/json

###

### Projects - Get by id
GET {{apiBase}}/api/projects/1
Accept: application/json

###

### Projects - Create
POST {{apiBase}}/api/projects
Content-Type: application/json

{
  "name": "Projet test",
  "description": "Projet cree depuis TaskFlowAPI.http",
  "creationDate": "2026-04-17T00:00:00",
  "user": {
    "name": "Pierre",
    "email": "pierre@example.com",
    "passwordHash": "hash-de-test",
    "role": 0
  }
}

###

### Tasks - Get all
GET {{apiBase}}/api/tasks
Accept: application/json

###

### Tasks - Get by id
GET {{apiBase}}/api/tasks/1
Accept: application/json

###

### Tasks - Create
POST {{apiBase}}/api/tasks
Content-Type: application/json

